{
  "name": "linktree-portfolio",
  "version": "1.0.0",
  "description": "Portfólio Linktree com backend serverless para analytics e contato",
  "author": "Douglas Assumpcao Rodrigues",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "netlify dev",
    "dev:client": "live-server --port=3000 --watch=./",
    "build": "npm run build:clean && npm run build:html && npm run build:css && npm run build:js && npm run build:assets",
    "build:clean": "rimraf dist && mkdirp dist",
    "build:html": "html-minifier --collapse-whitespace --remove-comments --remove-optional-tags --remove-redundant-attributes --remove-script-type-attributes --remove-tag-whitespace --use-short-doctype --minify-css true --minify-js true --input-dir . --output-dir dist --file-ext html",
    "build:css": "cleancss -O2 --output dist/css/ --batch --batch-suffix '' css/*.css",
    "build:js": "terser js/*.js -c -m -o dist/js/ --source-map url=inline",
    "build:assets": "copyfiles -u 1 assets/** dist/",
    "preview": "serve dist -p 3000",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "deploy": "npm run build && npm run deploy:vercel",
    "test": "npm run test:api",
    "test:api": "node --test test/api/*.test.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md,html,css}\"",
    "health": "curl -s https://douglas-rodrigues.vercel.app/api/health | jq .",
    "supabase:init": "node scripts/supabase-init.js",
    "supabase:migrate": "psql -f scripts/supabase-schema.sql",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:robots": "node scripts/generate-robots.js",
    "analyze": "npm run analyze:bundle && npm run analyze:performance",
    "analyze:bundle": "webpack-bundle-analyzer stats.json",
    "analyze:performance": "lighthouse https://douglas-rodrigues.vercel.app --output=json --output-path=reports/lighthouse.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "resend": "^3.0.0",
    "@sendgrid/mail": "^7.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "helmet": "^7.0.0",
    "rate-limiter-flexible": "^3.0.0",
    "uuid": "^9.0.0",
    "validator": "^13.9.0"
  },
  "devDependencies": {
    "@netlify/functions": "^2.0.0",
    "@vercel/node": "^3.0.0",
    "concurrently": "^8.2.0",
    "copyfiles": "^2.4.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "html-minifier": "^4.0.0",
    "jshint": "^2.13.6",
    "live-server": "^1.2.2",
    "mkdirp": "^3.0.0",
    "netlify-cli": "^15.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "serve": "^14.2.0",
    "terser": "^5.19.0",
    "clean-css-cli": "^5.0.0",
    "vercel": "^32.0.0",
    "webpack-bundle-analyzer": "^4.8.0",
    "lighthouse": "^11.0.0"
  },
  "keywords": [
    "portfolio",
    "linktree",
    "mainframe",
    "serverless",
    "analytics",
    "supabase",
    "vercel",
    "netlify"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/douglas-rodrigues/linktree-portfolio.git"
  },
  "bugs": {
    "url": "https://github.com/douglas-rodrigues/linktree-portfolio/issues"
  },
  "homepage": "https://douglas-rodrigues.vercel.app",
  "browserslist": [
    "defaults",
    "not IE 11",
    "maintained node versions"
  ],
  "volta": {
    "node": "18.17.0",
    "npm": "9.6.7"
  }
}