# Environment Variables for Linktree Portfolio Backend
# Copy this file to .env.local for local development
# For production, set these variables in your hosting platform (Vercel/Netlify)

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here # Optional, for admin operations

# ============================================
# EMAIL SERVICE CONFIGURATION
# ============================================
# Choose one email service (Resend recommended for Vercel)
RESEND_API_KEY=re_1234567890abcdef # Get from https://resend.com
# OR use SendGrid
SENDGRID_API_KEY=SG.1234567890abcdef # Get from https://sendgrid.com

# Email addresses
CONTACT_EMAIL=contato@douglasrodrigues.dev # Where contact form emails are sent
REPLY_TO_EMAIL=noreply@douglasrodrigues.dev # From address for emails
ADMIN_EMAIL=admin@douglasrodrigues.dev # For notifications

# ============================================
# SECURITY & CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=https://douglas-rodrigues.vercel.app,https://douglas-rodrigues.netlify.app,http://localhost:3000
NODE_ENV=development # production, development, test
APP_SECRET=your-app-secret-key-here # For signing tokens, etc.

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000 # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS=10 # Max requests per window
CONTACT_RATE_LIMIT_MAX=5 # More strict for contact form

# ============================================
# ANALYTICS & MONITORING
# ============================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX # Optional
SENTRY_DSN=https://xxx@sentry.io/xxx # Optional
LOG_LEVEL=info # debug, info, warn, error

# ============================================
# PERFORMANCE & CACHE
# ============================================
CACHE_TTL_MS=30000 # 30 seconds
ENABLE_CACHE=true
MAX_REQUEST_SIZE_MB=5

# ============================================
# DEPLOYMENT
# ============================================
VERSION=1.0.0
REGION=gru1 # Vercel/Netlify region
DEPLOYMENT_ID=vercel-${VERCEL_GIT_COMMIT_SHA:-local}

# ============================================
# DEVELOPMENT OVERRIDES
# ============================================
# Uncomment for local development
# SKIP_EMAIL_SENDING=true # Don't actually send emails
# MOCK_SUPABASE=true # Use mock Supabase client
# DEBUG=true # Enable verbose logging